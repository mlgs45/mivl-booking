# ── Base de données ──────────────────────────────────────────────────────────
# Dev local : postgresql://postgres:postgres@localhost:5432/mivl_booking
# Prod (data-01 Hetzner) : postgresql://USER:PASSWORD@data-01-ip:5432/mivl_booking
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mivl_booking

# ── Auth.js v5 ───────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32
AUTH_URL=https://connect.mivl-orleans.fr
# Nécessaire derrière le reverse proxy Coolify/Traefik
AUTH_TRUST_HOST=true
# Dev local :
# AUTH_URL=http://localhost:3000

# ── Email (Brevo) ─────────────────────────────────────────────────────────────
# À récupérer sur https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=
BREVO_FROM_EMAIL=noreply@mivl-orleans.fr
BREVO_FROM_NAME="MIVL Connect"
# En dev, les emails sont loggés dans la console (MODE=development)
# Pour tester Brevo en local, renseigner la clé et passer EMAIL_PROVIDER=brevo
EMAIL_PROVIDER=console

# ── QR Codes ─────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
QR_SIGNING_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="MIVL Connect"
NEXT_PUBLIC_APP_URL=https://connect.mivl-orleans.fr

# Super admin (créé automatiquement au seed)
SUPER_ADMIN_EMAIL=mathieu.langlois@centre.cci.fr

# Uploads locaux (badges, plannings générés)
STORAGE_DIR=/app/uploads

# ── Infra ────────────────────────────────────────────────────────────────────
# NODE_ENV=production en prod (géré par Docker/Coolify, ne pas surcharger ici)
NODE_ENV=development
